{
  "name": "Canvas Coding Assistant",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Suggestions while coding in Canvas using a GPU-hosted Qwen model.",
  "action": {
    "default_title": "Canvas Coding Assistant",
    "default_popup": "popup.html"
  },
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://canvas.uh.edu/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://canvas.uh.edu/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}